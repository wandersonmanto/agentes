# =====================================================================
# Backend — Margem Negativa
# =====================================================================

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=http://10.0.0.20:5173,http://margem.interno

# API local de margem
LOCAL_API_URL=http://192.168.118.50:3001/api/margem
LOCAL_API_TIMEOUT_MS=30000

# Token compartilhado com n8n p/ proteger /sync/run
SYNC_TOKEN=trocar-por-segredo-longo-e-aleatorio

# Supabase (service_role — somente backend, nunca exponha ao frontend)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Firebase Admin — caminho do JSON da service account
# Mantenha o arquivo FORA do controle de versão
FIREBASE_SERVICE_ACCOUNT_PATH=./.secrets/firebase-service-account.json
# Alternativamente, conteúdo base64:
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Cache do Firestore (em segundos)
FIRESTORE_CACHE_TTL=3600

# Sync horário do agente margem — o backend dispara o ciclo sozinho.
# Formato cron de 5 campos (m h d M w). Deixe vazio se quiser desligar.
SYNC_CRON=0 */1 * * *

# Sync diário do agente metas (1 leitura por filial no Firestore).
# Sugerido: 04:00 — pega o doc do dia já fechado do BI.
METAS_SYNC_CRON=0 4 * * *
