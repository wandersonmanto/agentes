# =====================================================================
# Frontend — Plataforma de Agentes
# =====================================================================
#
# A URL do backend NÃO fica aqui: ela é resolvida por MODO, via arquivos
# versionados no repositório:
#   .env.development  -> http://localhost:3000        (npm run dev)
#   .env.production   -> http://192.168.118.90:3000   (npm run build)
#
# Este .env guarda só a config ESPECÍFICA DA MÁQUINA (Firebase), e não é
# versionado. Copie para .env e preencha:

# Firebase Web Config (Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=preco-b17ba.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=preco-b17ba
VITE_FIREBASE_STORAGE_BUCKET=preco-b17ba.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Restrição de domínio no login (vazio = qualquer e-mail)
VITE_AUTH_ALLOWED_DOMAIN=
